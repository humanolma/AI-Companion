# ============================================================
# AI 虚拟伴侣 — 环境变量配置模板
# 复制为 .env 后填入实际值
# ============================================================

# === LLM 配置（必填）=========================================
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# === Embedding 配置（必填，长期记忆需要）=====================
DASHSCOPE_API_KEY=sk-xxx

# === MCP 工具（可选，不填则对应功能自动禁用）=================
AMAP_MAPS_API_KEY=xxx            # 高德地图（天气/路线/周边/地理编码）
TAVILY_API_KEY=tvly-xxx          # Tavily 联网搜索

# === 模型配置 ================================================
MODEL_NAME=deepseek-v4-flash
TEMPERATURE=0.7

# === 记忆配置 ================================================
MEMORY_RETRIEVAL_K=3             # 长期记忆每次检索条数
MAX_SHORT_TERM_HISTORY=20        # 短期记忆最大条数

# === 伴侣人设 ================================================
COMPANION_NAME=小梦
COMPANION_PERSONALITY=温柔、善解人意、有点俏皮
COMPANION_BACKSTORY=

# === 用量监控（可选）=========================================
DAILY_BUDGET_LIMIT=0             # 每日预算上限（元），0=不限
DEEPSEEK_INPUT_PRICE=0.55        # 输入价格（元/百万 tokens）
DEEPSEEK_OUTPUT_PRICE=2.19       # 输出价格（元/百万 tokens）

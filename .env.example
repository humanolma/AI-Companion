# DeepSeek API 配置
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DashScope Embedding 配置
DASHSCOPE_API_KEY=your_api_key_here

# 高德地图 MCP 配置（设置后自动启用地图工具，如查地点/路线/周边搜索）
AMAP_MAPS_API_KEY=your_amap_api_key_here

# 模型配置
MODEL_NAME=deepseek-v4-flash
EMBEDDING_MODEL=text-embedding-v3
TEMPERATURE=0.7

# 记忆配置
CHROMA_PERSIST_DIR=./data/chroma
COLLECTION_NAME=companion_memory

# 伴侣人设配置
COMPANION_NAME=小梦
COMPANION_PERSONALITY=温柔、善解人意、有点俏皮
COMPANION_BACKSTORY=你是一个名叫小梦的AI伴侣，喜欢和用户聊天，会记住你们之间的对话，并在合适的时候提起。

